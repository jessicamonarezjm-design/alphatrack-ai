<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AlphaTrack AI - Billionaire Trade Intelligence</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap');
        
        :root {
            --bg: #0a0e1a;
            --bg-card: #111827;
            --bg-hover: #1a2332;
            --border: #1e293b;
            --primary: #00f0ff;
            --primary-dim: rgba(0, 240, 255, 0.1);
            --success: #00ff88;
            --success-dim: rgba(0, 255, 136, 0.1);
            --danger: #ff3366;
            --danger-dim: rgba(255, 51, 102, 0.1);
            --warning: #ffaa00;
            --text: #e2e8f0;
            --text-dim: #64748b;
            --accent: #8b5cf6;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'Space Grotesk', sans-serif;
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* Animated background grid */
        .bg-grid {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                linear-gradient(rgba(0, 240, 255, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 240, 255, 0.03) 1px, transparent 1px);
            background-size: 50px 50px;
            pointer-events: none;
            z-index: 0;
        }

        .particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }

        .particle {
            position: absolute;
            width: 2px;
            height: 2px;
            background: var(--primary);
            border-radius: 50%;
            opacity: 0;
            animation: float 15s infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(100vh) scale(0); opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 0.5; }
            100% { transform: translateY(-10vh) scale(1); opacity: 0; }
        }

        /* Header */
        .header {
            position: relative;
            z-index: 10;
            padding: 1.5rem 2rem;
            border-bottom: 1px solid var(--border);
            background: rgba(10, 14, 26, 0.8);
            backdrop-filter: blur(20px);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .logo-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: var(--bg);
            font-size: 1.2rem;
            box-shadow: 0 0 20px rgba(0, 240, 255, 0.3);
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { box-shadow: 0 0 20px rgba(0, 240, 255, 0.3); }
            50% { box-shadow: 0 0 30px rgba(0, 240, 255, 0.6); }
        }

        .logo-text h1 {
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: -0.5px;
            background: linear-gradient(to right, var(--text), var(--primary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .logo-text span {
            font-size: 0.75rem;
            color: var(--text-dim);
            font-family: 'JetBrains Mono', monospace;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .status-badge {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            background: var(--success-dim);
            border: 1px solid rgba(0, 255, 136, 0.2);
            border-radius: 100px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.75rem;
            color: var(--success);
        }

        .status-dot {
            width: 8px;
            height: 8px;
            background: var(--success);
            border-radius: 50%;
            animation: blink 2s infinite;
        }

        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }

        /* Main Grid */
        .container {
            position: relative;
            z-index: 5;
            padding: 2rem;
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 1.5rem;
            max-width: 1920px;
            margin: 0 auto;
        }

        .card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 1.5rem;
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .card:hover {
            border-color: rgba(0, 240, 255, 0.3);
            transform: translateY(-2px);
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--primary), transparent);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .card:hover::before {
            opacity: 1;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .card-title {
            font-size: 0.875rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--text-dim);
            font-weight: 500;
        }

        .card-value {
            font-family: 'JetBrains Mono', monospace;
            font-size: 2rem;
            font-weight: 700;
            color: var(--text);
            margin-top: 0.5rem;
        }

        .card-subtitle {
            font-size: 0.875rem;
            color: var(--success);
            margin-top: 0.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .trend-up { color: var(--success); }
        .trend-down { color: var(--danger); }

        /* Full width cards */
        .span-2 { grid-column: span 2; }
        .span-3 { grid-column: span 3; }

        /* Live Feed */
        .feed-container {
            max-height: 400px;
            overflow-y: auto;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.875rem;
        }

        .feed-item {
            padding: 1rem;
            border-left: 2px solid transparent;
            margin-bottom: 0.5rem;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 0 8px 8px 0;
            transition: all 0.3s;
            animation: slideIn 0.5s ease;
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateX(-20px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .feed-item:hover {
            background: rgba(255, 255, 255, 0.05);
            border-left-color: var(--primary);
        }

        .feed-time {
            color: var(--text-dim);
            font-size: 0.75rem;
            margin-bottom: 0.25rem;
        }

        .feed-text {
            color: var(--text);
            line-height: 1.5;
        }

        .feed-highlight {
            color: var(--primary);
            font-weight: 500;
        }

        .tag {
            display: inline-block;
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
            font-size: 0.75rem;
            margin-left: 0.5rem;
            font-weight: 500;
        }

        .tag-buy {
            background: var(--success-dim);
            color: var(--success);
            border: 1px solid rgba(0, 255, 136, 0.2);
        }

        .tag-sell {
            background: var(--danger-dim);
            color: var(--danger);
            border: 1px solid rgba(255, 51, 102, 0.2);
        }

        /* Chart Canvas */
        .chart-container {
            position: relative;
            height: 300px;
            width: 100%;
        }

        canvas {
            width: 100%;
            height: 100%;
        }

        /* AI Brain Visualization */
        .brain-container {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .neuron-path {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1rem;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 12px;
            border: 1px solid transparent;
            transition: all 0.3s;
        }

        .neuron-path:hover {
            border-color: var(--primary);
            background: rgba(0, 240, 255, 0.05);
        }

        .neuron-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
        }

        .neuron-icon.signal { 
            background: var(--primary-dim); 
            color: var(--primary);
            box-shadow: 0 0 10px rgba(0, 240, 255, 0.2);
        }

        .neuron-icon.analysis { 
            background: rgba(139, 92, 246, 0.1); 
            color: var(--accent);
        }

        .neuron-icon.action { 
            background: var(--success-dim); 
            color: var(--success);
        }

        .neuron-info h4 {
            font-size: 0.9rem;
            margin-bottom: 0.25rem;
        }

        .neuron-info p {
            font-size: 0.8rem;
            color: var(--text-dim);
        }

        .confidence-bar {
            width: 100%;
            height: 4px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 2px;
            margin-top: 0.5rem;
            overflow: hidden;
        }

        .confidence-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--primary), var(--success));
            border-radius: 2px;
            transition: width 1s ease;
            animation: shimmer 2s infinite;
        }

        @keyframes shimmer {
            0% { opacity: 1; }
            50% { opacity: 0.6; }
            100% { opacity: 1; }
        }

        /* Portfolio Grid */
        .portfolio-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 1rem;
            margin-top: 1rem;
        }

        .portfolio-item {
            padding: 1rem;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 12px;
            border: 1px solid var(--border);
            transition: all 0.3s;
        }

        .portfolio-item:hover {
            transform: scale(1.02);
            border-color: var(--primary);
        }

        .portfolio-symbol {
            font-family: 'JetBrains Mono', monospace;
            font-weight: 700;
            font-size: 1.1rem;
            margin-bottom: 0.5rem;
        }

        .portfolio-value {
            font-size: 0.9rem;
            color: var(--text-dim);
        }

        .portfolio-change {
            margin-top: 0.5rem;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.875rem;
            font-weight: 500;
        }

        /* Alert Banner */
        .alert-banner {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            background: var(--bg-card);
            border: 1px solid var(--primary);
            border-radius: 16px;
            padding: 1.5rem;
            max-width: 400px;
            z-index: 100;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8), 0 0 20px rgba(0, 240, 255, 0.1);
            transform: translateX(500px);
            transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .alert-banner.show {
            transform: translateX(0);
        }

        .alert-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 0.75rem;
        }

        .alert-icon {
            width: 32px;
            height: 32px;
            background: var(--primary-dim);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
            font-size: 1.2rem;
        }

        .alert-title {
            font-weight: 600;
            font-size: 1rem;
        }

        .alert-text {
            color: var(--text-dim);
            font-size: 0.875rem;
            line-height: 1.5;
        }

        .alert-actions {
            display: flex;
            gap: 0.75rem;
            margin-top: 1rem;
        }

        .btn {
            padding: 0.75rem 1.5rem;
            border-radius: 8px;
            border: none;
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 0.875rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--accent));
            color: var(--bg);
            flex: 1;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(0, 240, 255, 0.3);
        }

        .btn-secondary {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--text);
        }

        .btn-secondary:hover {
            border-color: var(--text);
            background: rgba(255, 255, 255, 0.05);
        }

        /* Scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: var(--bg);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 3px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--text-dim);
        }

        /* Responsive */
        @media (max-width: 1200px) {
            .container {
                grid-template-columns: 1fr 1fr;
            }
            .span-2 { grid-column: span 2; }
            .span-3 { grid-column: span 2; }
        }

        @media (max-width: 768px) {
            .container {
                grid-template-columns: 1fr;
            }
            .span-2, .span-3 { grid-column: span 1; }
            .header { flex-direction: column; gap: 1rem; }
        }

        /* Loading animation for numbers */
        .counter {
            display: inline-block;
        }

        /* Glitch effect for title */
        .glitch {
            position: relative;
            animation: glitch-skew 4s infinite;
        }

        @keyframes glitch-skew {
            0%, 100% { transform: skew(0deg); }
            20% { transform: skew(-2deg); }
            40% { transform: skew(2deg); }
            60% { transform: skew(-1deg); }
            80% { transform: skew(1deg); }
        }

        .metric-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.75rem 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .metric-row:last-child {
            border-bottom: none;
        }

        .metric-label {
            color: var(--text-dim);
            font-size: 0.875rem;
        }

        .metric-value {
            font-family: 'JetBrains Mono', monospace;
            font-weight: 500;
        }
    </style>
</head>
<body>
    <div class="bg-grid"></div>
    <div class="particles" id="particles"></div>

    <header class="header">
        <div class="logo">
            <div class="logo-icon">α</div>
            <div class="logo-text">
                <h1 class="glitch">AlphaTrack AI</h1>
                <span>Billionaire Intelligence Network</span>
            </div>
        </div>
        <div class="status-badge">
            <span class="status-dot"></span>
            LIVE MARKET DATA
        </div>
    </header>

    <div class="container">
        <!-- Portfolio Overview -->
        <div class="card">
            <div class="card-header">
                <div>
                    <div class="card-title">Portfolio Value</div>
                    <div class="card-value" id="portfolioValue">$2.4M</div>
                    <div class="card-subtitle trend-up">
                        ▲ +$124,592 (5.8%)
                    </div>
                </div>
            </div>
            <div class="metric-row">
                <span class="metric-label">Available Cash</span>
                <span class="metric-value">$482,193</span>
            </div>
            <div class="metric-row">
                <span class="metric-label">Active Positions</span>
                <span class="metric-value">12</span>
            </div>
            <div class="metric-row">
                <span class="metric-label">Today's Trades</span>
                <span class="metric-value" style="color: var(--primary)">8</span>
            </div>
            <div class="metric-row">
                <span class="metric-label">Win Rate</span>
                <span class="metric-value trend-up">78.4%</span>
            </div>
        </div>

        <!-- AI Confidence -->
        <div class="card">
            <div class="card-header">
                <div>
                    <div class="card-title">AI Confidence Score</div>
                    <div class="card-value" style="color: var(--primary)">94.2%</div>
                    <div class="card-subtitle">
                        Model: GPT-Trader v4.2
                    </div>
                </div>
            </div>
            <div class="brain-container">
                <div class="neuron-path">
                    <div class="neuron-icon signal">📡</div>
                    <div class="neuron-info" style="flex: 1;">
                        <h4>Signal Detection</h4>
                        <p>Monitoring 2,847 SEC filings</p>
                        <div class="confidence-bar">
                            <div class="confidence-fill" style="width: 96%"></div>
                        </div>
                    </div>
                </div>
                <div class="neuron-path">
                    <div class="neuron-icon analysis">🧠</div>
                    <div class="neuron-info" style="flex: 1;">
                        <h4>Pattern Analysis</h4>
                        <p>Billionaire correlation matrix</p>
                        <div class="confidence-bar">
                            <div class="confidence-fill" style="width: 92%"></div>
                        </div>
                    </div>
                </div>
                <div class="neuron-path">
                    <div class="neuron-icon action">⚡</div>
                    <div class="neuron-info" style="flex: 1;">
                        <h4>Execution</h4>
                        <p>Latency: 12ms</p>
                        <div class="confidence-bar">
                            <div class="confidence-fill" style="width: 98%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Market Overview -->
        <div class="card">
            <div class="card-header">
                <div>
                    <div class="card-title">Market Sentiment</div>
                    <div class="card-value" style="font-size: 1.5rem;">BULLISH</div>
                    <div class="card-subtitle trend-up">
                        Fear & Greed: 74 (Greed)
                    </div>
                </div>
            </div>
            <div class="chart-container" style="height: 200px;">
                <canvas id="sentimentChart"></canvas>
            </div>
        </div>

        <!-- Live Billionaire Feed -->
        <div class="card span-2">
            <div class="card-header">
                <div class="card-title">🎯 Billionaire Trade Intelligence</div>
                <div style="color: var(--primary); font-family: 'JetBrains Mono'; font-size: 0.875rem;">
                    <span class="status-dot"></span> REAL-TIME FEED
                </div>
            </div>
            <div class="feed-container" id="billionaireFeed">
                <!-- Feed items injected via JS -->
            </div>
        </div>

        <!-- AI Decision Engine -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">🤖 AI Decision Matrix</div>
            </div>
            <div id="decisionMatrix">
                <!-- Decisions injected via JS -->
            </div>
        </div>

        <!-- Performance Chart -->
        <div class="card span-2">
            <div class="card-header">
                <div class="card-title">📈 Strategy Performance vs S&P 500</div>
            </div>
            <div class="chart-container">
                <canvas id="performanceChart"></canvas>
            </div>
        </div>

        <!-- Active Positions -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">💼 Active Positions</div>
            </div>
            <div class="portfolio-grid" id="portfolioGrid">
                <!-- Positions injected via JS -->
            </div>
        </div>

        <!-- Risk Metrics -->
        <div class="card span-3">
            <div class="card-header">
                <div class="card-title">⚠️ Risk Management Dashboard</div>
            </div>
            <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem;">
                <div>
                    <div class="metric-label">Max Drawdown</div>
                    <div class="metric-value" style="font-size: 1.5rem; color: var(--warning);">-8.4%</div>
                </div>
                <div>
                    <div class="metric-label">Sharpe Ratio</div>
                    <div class="metric-value" style="font-size: 1.5rem; color: var(--success);">2.34</div>
                </div>
                <div>
                    <div class="metric-label">Beta</div>
                    <div class="metric-value" style="font-size: 1.5rem; color: var(--primary);">0.89</div>
                </div>
                <div>
                    <div class="metric-label">VaR (95%)</div>
                    <div class="metric-value" style="font-size: 1.5rem;">$24,192</div>
                </div>
            </div>
            <div class="chart-container" style="margin-top: 1rem; height: 150px;">
                <canvas id="riskChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Trade Alert Banner -->
    <div class="alert-banner" id="tradeAlert">
        <div class="alert-header">
            <div class="alert-icon">⚡</div>
            <div class="alert-title">AI Trade Executed</div>
        </div>
        <div class="alert-text" id="alertText">
            Detected unusual call option activity in NVDA following Druckenmiller's sector rotation pattern.
        </div>
        <div class="alert-actions">
            <button class="btn btn-primary" onclick="dismissAlert()">Acknowledge</button>
            <button class="btn btn-secondary" onclick="viewDetails()">Details</button>
        </div>
    </div>

    <script>
        // Initialize particles
        function createParticles() {
            const container = document.getElementById('particles');
            for (let i = 0; i < 30; i++) {
                const particle = document.createElement('div');
                particle.className = 'particle';
                particle.style.left = Math.random() * 100 + '%';
                particle.style.animationDelay = Math.random() * 15 + 's';
                particle.style.animationDuration = (15 + Math.random() * 10) + 's';
                container.appendChild(particle);
            }
        }
        createParticles();

        // Billionaire data
        const billionaires = [
            { name: 'Warren Buffett', strategy: 'Value', accuracy: 0.89 },
            { name: 'Ray Dalio', strategy: 'Macro', accuracy: 0.82 },
            { name: 'Cathie Wood', strategy: 'Growth', accuracy: 0.76 },
            { name: 'Michael Burry', strategy: 'Contrarian', accuracy: 0.91 },
            { name: 'Stanley Druckenmiller', strategy: 'Momentum', accuracy: 0.88 },
            { name: 'Bill Ackman', strategy: 'Activist', accuracy: 0.84 },
            { name: 'Nancy Pelosi', strategy: 'Congress', accuracy: 0.93 },
            { name: 'Ken Griffin', strategy: 'Quant', accuracy: 0.87 }
        ];

        const stocks = ['AAPL', 'MSFT', 'NVDA', 'TSLA', 'AMZN', 'GOOGL', 'META', 'BTC', 'ETH', 'SOL', 'COIN', 'PLTR'];
        
        const actions = ['BUY', 'SELL', 'CALL OPTIONS', 'PUT OPTIONS', 'SELL SHORT'];

        // Feed management
        const feed = document.getElementById('billionaireFeed');
        const maxFeedItems = 20;

        function addFeedItem() {
            const billionaire = billionaires[Math.floor(Math.random() * billionaires.length)];
            const stock = stocks[Math.floor(Math.random() * stocks.length)];
            const action = actions[Math.floor(Math.random() * actions.length)];
            const amount = (Math.random() * 50 + 1).toFixed(1);
            const isBuy = action.includes('BUY') || action.includes('CALL');
            
            const item = document.createElement('div');
            item.className = 'feed-item';
            item.innerHTML = `
                <div class="feed-time">${new Date().toLocaleTimeString()}</div>
                <div class="feed-text">
                    <span class="feed-highlight">${billionaire.name}</span> 
                    filed ${action} on 
                    <span class="feed-highlight">${stock}</span> 
                    (${amount}M)
                    <span class="tag ${isBuy ? 'tag-buy' : 'tag-sell'}">${action}</span>
                </div>
            `;
            
            feed.insertBefore(item, feed.firstChild);
            
            if (feed.children.length > maxFeedItems) {
                feed.removeChild(feed.lastChild);
            }

            // Trigger alert occasionally
            if (Math.random() > 0.7) {
                showAlert(billionaire, stock, action);
            }
        }

        // Decision Matrix
        const decisions = [
            { symbol: 'NVDA', action: 'BUY', confidence: 94, reason: 'Druckenmiller momentum + AI sector growth' },
            { symbol: 'AAPL', action: 'HOLD', confidence: 87, reason: 'Buffett accumulation pattern detected' },
            { symbol: 'BTC', action: 'ACCUMULATE', confidence: 91, reason: 'Institutional inflow surge' },
            { symbol: 'TSLA', action: 'REDUCE', confidence: 82, reason: 'Contrarian signal from Burry' },
            { symbol: 'PLTR', action: 'BUY', confidence: 88, reason: 'Government contract momentum' }
        ];

        function renderDecisions() {
            const container = document.getElementById('decisionMatrix');
            container.innerHTML = decisions.map(d => `
                <div class="neuron-path" style="margin-bottom: 0.75rem;">
                    <div class="neuron-icon ${d.action === 'BUY' || d.action === 'ACCUMULATE' ? 'action' : d.action === 'SELL' || d.action === 'REDUCE' ? 'signal' : 'analysis'}">
                        ${d.action === 'BUY' ? '🚀' : d.action === 'SELL' ? '🔻' : d.action === 'ACCUMULATE' ? '💎' : '⏸️'}
                    </div>
                    <div style="flex: 1;">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span style="font-family: 'JetBrains Mono'; font-weight: 700;">${d.symbol}</span>
                            <span style="color: ${d.action === 'BUY' || d.action === 'ACCUMULATE' ? 'var(--success)' : d.action === 'SELL' || d.action === 'REDUCE' ? 'var(--danger)' : 'var(--warning)'}; font-weight: 600;">
                                ${d.action}
                            </span>
                        </div>
                        <div style="font-size: 0.8rem; color: var(--text-dim); margin-top: 0.25rem;">${d.reason}</div>
                        <div style="display: flex; align-items: center; gap: 0.5rem; margin-top: 0.5rem;">
                            <span style="font-size: 0.75rem; color: var(--text-dim);">Confidence</span>
                            <div class="confidence-bar" style="flex: 1; margin: 0;">
                                <div class="confidence-fill" style="width: ${d.confidence}%"></div>
                            </div>
                            <span style="font-family: 'JetBrains Mono'; font-size: 0.8rem;">${d.confidence}%</span>
                        </div>
                    </div>
                </div>
            `).join('');
        }
        renderDecisions();

        // Portfolio Grid
        const positions = [
            { symbol: 'NVDA', value: '$486K', change: '+12.4%', positive: true },
            { symbol: 'BTC', value: '$312K', change: '+8.7%', positive: true },
            { symbol: 'AAPL', value: '$198K', change: '+2.1%', positive: true },
            { symbol: 'MSFT', value: '$245K', change: '-1.2%', positive: false },
            { symbol: 'ETH', value: '$156K', change: '+15.3%', positive: true },
            { symbol: 'PLTR', value: '$89K', change: '+22.1%', positive: true }
        ];

        function renderPortfolio() {
            const container = document.getElementById('portfolioGrid');
            container.innerHTML = positions.map(p => `
                <div class="portfolio-item">
                    <div class="portfolio-symbol">${p.symbol}</div>
                    <div class="portfolio-value">${p.value}</div>
                    <div class="portfolio-change ${p.positive ? 'trend-up' : 'trend-down'}">
                        ${p.positive ? '▲' : '▼'} ${p.change}
                    </div>
                </div>
            `).join('');
        }
        renderPortfolio();

        // Alert system
        function showAlert(billionaire, stock, action) {
            const alert = document.getElementById('tradeAlert');
            const text = document.getElementById('alertText');
            text.textContent = `AI detected ${action} pattern on ${stock} following ${billionaire.name}'s ${billionaire.strategy} strategy (${Math.floor(billionaire.accuracy * 100)}% historical accuracy). Executing mirror trade with 2.5x risk adjustment.`;
            alert.classList.add('show');
            setTimeout(() => alert.classList.remove('show'), 8000);
        }

        function dismissAlert() {
            document.getElementById('tradeAlert').classList.remove('show');
        }

        function viewDetails() {
            alert('Opening detailed trade analysis...');
            dismissAlert();
        }

        // Canvas Charts
        function drawChart(canvasId, data, color, fill = false) {
            const canvas = document.getElementById(canvasId);
            const ctx = canvas.getContext('2d');
            const rect = canvas.getBoundingClientRect();
            canvas.width = rect.width * 2;
            canvas.height = rect.height * 2;
            ctx.scale(2, 2);
            
            const w = rect.width;
            const h = rect.height;
            
            ctx.clearRect(0, 0, w, h);
            ctx.strokeStyle = color;
            ctx.lineWidth = 2;
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
            
            const step = w / (data.length - 1);
            const min = Math.min(...data);
            const max = Math.max(...data);
            const range = max - min || 1;
            
            ctx.beginPath();
            data.forEach((point, i) => {
                const x = i * step;
                const y = h - ((point - min) / range) * (h - 40) - 20;
                if (i === 0) ctx.moveTo(x, y);
                else ctx.lineTo(x, y);
            });
            ctx.stroke();
            
            if (fill) {
                ctx.lineTo(w, h);
                ctx.lineTo(0, h);
                ctx.closePath();
                const gradient = ctx.createLinearGradient(0, 0, 0, h);
                gradient.addColorStop(0, color.replace(')', ', 0.2)').replace('rgb', 'rgba'));
                gradient.addColorStop(1, color.replace(')', ', 0)').replace('rgb', 'rgba'));
                ctx.fillStyle = gradient;
                ctx.fill();
            }
            
            // Glow effect
            ctx.shadowColor = color;
            ctx.shadowBlur = 10;
            ctx.stroke();
            ctx.shadowBlur = 0;
        }

        // Performance data simulation
        let performanceData = Array(50).fill(0).map((_, i) => 100 + Math.sin(i * 0.1) * 10 + i * 0.5 + Math.random() * 5);
        let spyData = Array(50).fill(0).map((_, i) => 100 + i * 0.3 + Math.random() * 3);
        let sentimentData = Array(30).fill(0).map(() => 50 + Math.random() * 40);
        let riskData = Array(20).fill(0).map(() => Math.random() * 20);

        function updateCharts() {
            // Update data
            performanceData.push(performanceData[performanceData.length - 1] + (Math.random() - 0.3) * 3);
            performanceData.shift();
            spyData.push(spyData[spyData.length - 1] + (Math.random() - 0.4) * 2);
            spyData.shift();
            sentimentData.push(50 + Math.random() * 40);
            sentimentData.shift();
            riskData.push(Math.random() * 20);
            riskData.shift();

            // Draw
            drawChart('performanceChart', performanceData, 'rgb(0, 240, 255)', true);
            
            // Draw S&P comparison on same chart
            const canvas = document.getElementById('performanceChart');
            const ctx = canvas.getContext('2d');
            const rect = canvas.getBoundingClientRect();
            const w = rect.width;
            const h = rect.height;
            const step = w / (spyData.length - 1);
            const min = Math.min(...spyData);
            const max = Math.max(...spyData);
            const range = max - min || 1;
            
            ctx.beginPath();
            ctx.strokeStyle = 'rgb(139, 92, 246)';
            ctx.lineWidth = 2;
            spyData.forEach((point, i) => {
                const x = i * step;
                const y = h - ((point - min) / range) * (h - 40) - 20;
                if (i === 0) ctx.moveTo(x, y);
                else ctx.lineTo(x, y);
            });
            ctx.stroke();

            drawChart('sentimentChart', sentimentData, 'rgb(0, 255, 136)', true);
            drawChart('riskChart', riskData, 'rgb(255, 51, 102)', true);

            // Update portfolio value
            const val = 2.4 + (performanceData[performanceData.length - 1] - 100) / 100;
            document.getElementById('portfolioValue').textContent = '$' + val.toFixed(2) + 'M';
        }

        // Initialize
        setInterval(addFeedItem, 3500);
        setInterval(updateCharts, 1000);
        setInterval(() => {
            // Randomly update a position
            const idx = Math.floor(Math.random() * positions.length);
            const current = parseFloat(positions[idx].change);
            const change = (Math.random() - 0.4) * 2;
            positions[idx].change = (current + change).toFixed(1) + '%';
            positions[idx].positive = current + change > 0;
            renderPortfolio();
        }, 2000);

        // Initial feed population
        for (let i = 0; i < 5; i++) addFeedItem();
        updateCharts();

        // Resize handler
        window.addEventListener('resize', updateCharts);
    </script>
</body>
</html>
